{
  "name": "brewpage-action",
  "version": "0.1.0",
  "private": true,
  "description": "Publish CI artefacts to BrewPage from a GitHub workflow in one step.",
  "type": "module",
  "main": "dist/index.js",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "build": "rimraf dist && rollup --config rollup.config.js",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "all": "npm run lint && npm test && npm run build"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "3.0.1"
  },
  "devDependencies": {
    "@rollup/plugin-commonjs": "29.0.3",
    "@rollup/plugin-json": "6.1.0",
    "@rollup/plugin-node-resolve": "16.0.3",
    "@rollup/plugin-typescript": "12.3.0",
    "@eslint/js": "10.0.1",
    "@types/jest": "30.0.0",
    "@types/node": "25.9.2",
    "eslint": "10.4.1",
    "jest": "30.4.2",
    "prettier": "3.8.4",
    "rimraf": "6.1.3",
    "rollup": "4.61.1",
    "ts-jest": "29.4.11",
    "tslib": "2.8.1",
    "typescript": "6.0.3",
    "typescript-eslint": "8.61.0"
  }
}
